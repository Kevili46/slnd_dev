{
  "name": "ai-agent-service",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --exec tsx --conditions=development src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#assets/*": {
      "development": "./src/assets/*.ts",
      "types": "./src/assets/*.ts",
      "default": "./dist/assets/*.js"
    },
    "#models/*": {
      "development": "./src/models/*.ts",
      "types": "./src/models/*.ts",
      "default": "./dist/models/*.js"
    },
    "#controllers/*": {
      "development": "./src/controllers/*.ts",
      "types": "./src/controllers/*.ts",
      "default": "./dist/controllers/*.js"
    },
    "#interfaces/*": {
      "development": "./src/interfaces/*.ts",
      "types": "./src/interfaces/*.ts",
      "default": "./dist/interfaces/*.js"
    },
    "#routes/*": {
      "development": "./src/routes/*.ts",
      "types": "./src/routes/*.ts",
      "default": "./dist/routes/*.js"
    },
    "#services/*": {
      "development": "./src/services/*.ts",
      "types": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#websockets/*": {
      "development": "./src/websockets/*.ts",
      "types": "./src/websockets/*.ts",
      "default": "./dist/websockets/*.js"
    },
    "#utils/*": {
      "development": "./src/utils/*.ts",
      "types": "./src/utils/*.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}